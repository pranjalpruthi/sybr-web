# SYBR web dashboard — client environment
# Copy to `.env` (or `.env.local`) and adjust. All vars are exposed to the
# browser, so never put secrets that must stay server-side here.

# Base URL of the SYBR FastAPI backend (see `api/` in the repo root).
VITE_SYBR_API_URL=http://192.168.25.76:8001/api/v1

# Optional: preload an API key so users don't have to paste one.
# When set, the sidebar shows "API key loaded from environment".
VITE_SYBR_API_KEY=

# Optional: password gate for the "All Jobs (Admin)" view.
# Leave unset to unlock with an empty password.
VITE_SYBR_ADMIN_PASSWORD=
